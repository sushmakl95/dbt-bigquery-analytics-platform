# Copy to .env (gitignored) for local dev.

# dbt target selection
DBT_TARGET=dev

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/home/you/keys/dbt-sa-dev.json
DBT_RAW_PROJECT=my-gcp-sandbox

# dbt profile directory (defaults to ~/.dbt)
DBT_PROFILES_DIR=/home/you/.dbt

# Optional: Cloud Composer DAGs bucket for deploy script
COMPOSER_DAGS_BUCKET=

# Optional: Slack webhook for freshness check alerts
SLACK_WEBHOOK_URL=
